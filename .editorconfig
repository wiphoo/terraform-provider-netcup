# EditorConfig — keep editor formatting consistent across contributors.
# Docs: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Go: tabs (matches gofmt), 4-column tab width.
[*.go]
indent_style = tab
indent_size = 4

# YAML / Markdown / JSON / HCL / Terraform: 2 spaces.
[*.{yml,yaml,md,json,hcl,tf}]
indent_style = space
indent_size = 2

# Shell scripts: 2 spaces.
[*.sh]
indent_style = space
indent_size = 2

# Makefiles require literal tabs.
[Makefile]
indent_style = tab
